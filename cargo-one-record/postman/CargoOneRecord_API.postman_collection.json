{
  "info": {
    "name": "Cargo ONE Record API",
    "description": "IATA ONE Record v2.0 — Airline Cargo Management System\n\nWorkflow:\n1. Register a user (Auth/Register)\n2. Login → token is auto-saved to {{token}}\n3. Create Company, TransportMeans\n4. Create Shipment → Pieces → Waybill\n5. Create BookingRequest → Confirm Booking\n6. Add LogisticsEvents to track cargo status\n7. Submit ChangeRequest → Review (approve/reject)\n8. View AuditTrail for full version history\n\nBase URL: {{baseUrl}} (default: http://localhost:8080)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "shipmentId", "value": "", "type": "string" },
    { "key": "pieceId", "value": "", "type": "string" },
    { "key": "waybillId", "value": "", "type": "string" },
    { "key": "companyId", "value": "", "type": "string" },
    { "key": "personId", "value": "", "type": "string" },
    { "key": "transportMeansId", "value": "", "type": "string" },
    { "key": "transportSegmentId", "value": "", "type": "string" },
    { "key": "bookingRequestId", "value": "", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" },
    { "key": "changeRequestId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"email\": \"admin@cargo.example.com\",\n  \"role\": \"ADMIN\",\n  \"companyIdentifier\": \"https://cargo.example.com\"\n}"
            }
          }
        },
        {
          "name": "Register Operator User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"operator1\",\n  \"password\": \"op123\",\n  \"email\": \"operator@cargo.example.com\",\n  \"role\": \"OPERATOR\",\n  \"companyIdentifier\": \"https://cargo.example.com\"\n}"
            }
          }
        },
        {
          "name": "Register Viewer User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"viewer1\",\n  \"password\": \"view123\",\n  \"email\": \"viewer@cargo.example.com\",\n  \"role\": \"VIEWER\",\n  \"companyIdentifier\": \"https://cargo.example.com\"\n}"
            }
          }
        },
        {
          "name": "Login (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved:', json.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login — Invalid Password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        }
      ]
    },
