{
  "info": {
    "name": "Items API",
    "description": "Complete API collection for the FastAPI Items Manager — Auth, Items CRUD, Search & Pagination.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8002",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns success message', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('registered successfully');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Regular User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"viewer\",\n  \"password\": \"viewer123\",\n  \"role\": \"user\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Role is user', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.role).to.eql('user');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin" },
                { "key": "password", "value": "admin123" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns access_token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.access_token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Invalid Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin" },
                { "key": "password", "value": "wrongpassword" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Returns error detail', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.detail).to.eql('Invalid username or password');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns username and role', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.username).to.be.a('string');",
                  "  pm.expect(json.role).to.be.oneOf(['admin', 'user']);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "Get All Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/items?page=1&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "5" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns items and pagination', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json).to.have.property('pagination');",
                  "  pm.expect(json.pagination.page).to.eql(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Items - Page 2",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/items?page=2&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "page_size", "value": "5" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/items?search=laptop&page=1&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                { "key": "search", "value": "laptop" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "5" }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns filtered results', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Filter by Price Range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/items?min_price=10&max_price=100&page=1&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                { "key": "min_price", "value": "10" },
                { "key": "max_price", "value": "100" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "5" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search + Price Filter",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/items?search=item&min_price=10&max_price=500&page=1&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                { "key": "search", "value": "item" },
                { "key": "min_price", "value": "10" },
                { "key": "max_price", "value": "500" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "5" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Item by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/items/1", "host": ["{{base_url}}"], "path": ["items", "1"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns item fields', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('id', 'name', 'description', 'price');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Item - Not Found",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/items/9999", "host": ["{{base_url}}"], "path": ["items", "9999"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Item (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/items", "host": ["{{base_url}}"], "path": ["items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"description\": \"RGB backlit, tactile switches\",\n  \"price\": 149.99\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns created item with id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.name).to.eql('Mechanical Keyboard');",
                  "  pm.collectionVariables.set('item_id', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Item - Forbidden (User role)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/items", "host": ["{{base_url}}"], "path": ["items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Should fail\",\n  \"description\": \"Regular users cannot create\",\n  \"price\": 1.00\n}"
            },
            "description": "Login as a 'user' role first, then run this — expects 403."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 for non-admin', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Item (Admin only)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/items/1", "host": ["{{base_url}}"], "path": ["items", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard v2\",\n  \"description\": \"Updated model with wrist rest\",\n  \"price\": 179.99\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Price updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.price).to.eql(179.99);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Item (Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/items/1", "host": ["{{base_url}}"], "path": ["items", "1"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns deleted message', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.include('deleted');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns welcome message', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
